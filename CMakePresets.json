{
  "version": 3,
  "configurePresets": [
  {
    "name": "default",
    "binaryDir": "build/default",
    "cacheVariables" :
    {
      "CMAKE_BUILD_TYPE" : "Debug"
    }
  },
  {
    "name": "release",
    "binaryDir": "build/release",
    "cacheVariables" :
    {
      "CMAKE_BUILD_TYPE" : "Release"
    }
  }],
  "buildPresets": [
  {
    "name": "default",
    "configurePreset": "default",
    "jobs" : 16
  },
  {
    "name": "release",
    "configurePreset": "release",
    "jobs": 16
  }]
}